{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "theme",
  "title": "Blank Slate Theme",
  "cssVars": {
    "theme": {
      "color-brand": "var(--brand)",
      "color-brand-shadow": "var(--brand-shadow)"
    },
    "light": {
      "primary": "#1e5fc8",
      "primary-foreground": "#ffffff",
      "secondary": "#e9f1ff",
      "secondary-foreground": "#0f2444",
      "accent": "#e9f1ff",
      "accent-foreground": "#0f2444",
      "ring": "#438eff",
      "brand": "#438eff",
      "brand-shadow": "#75bcff",
      "neutral-line": "#a1a1aa",
      "neutral-shadow": "#c9c9ce",
      "radius": "0.5rem"
    },
    "dark": {
      "primary": "#6ea8ff",
      "primary-foreground": "#08122b",
      "secondary": "#14233d",
      "secondary-foreground": "#e8f0ff",
      "accent": "#17294a",
      "accent-foreground": "#e8f0ff",
      "ring": "#75bcff",
      "brand": "#75bcff",
      "brand-shadow": "#2f6fd6",
      "neutral-line": "#6b6b73",
      "neutral-shadow": "#3f3f46",
      "border": "oklch(0.32 0 0)",
      "input": "oklch(0.37 0 0)"
    }
  },
  "type": "registry:theme"
}